#!/usr/bin/env bash
set -euo pipefail

# FR-BSH-01: ilink-init <story> <usage-value> - Create new Story directory and requirement template
# v1.6.0: <usage-value> 必填，记录 init 时刻的 Codex /status "Context window" used 值，用于后续 usage 追踪

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

# v1.6.0 必填校验：第二参数 <usage-value>
if [[ $# -lt 2 || -z "${2:-}" ]]; then
  echo "❌ 缺少 usage-value 参数。请先在 Codex 中执行 /status 查看 \"Context window\" 的 used 值，然后以下列格式重试：" >&2
  echo "" >&2
  echo "  /ilink-init <story-id> <Context window used 数字>" >&2
  echo "" >&2
  echo "例如，/status 显示 \"Context window: 12,000 / 200,000 (6%)\"，则执行：/ilink-init kcia-1520 12000" >&2
  echo "" >&2
  echo "**传入斜杠左侧的绝对 token 数（如 12000），不要传百分比（6）**——否则 Latest Delta 含义会被混淆。" >&2
  echo "无法查询时允许传入 0（语义为'故意跳过'，文件正常写入但 delta 标注不可信）。" >&2
  exit 2
fi

story_required "$@"
story="$1"
usage_value="$2"

# 校验 usage_value 为非负数字（整数或小数）
if ! [[ "$usage_value" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
  log_error "usage-value 必须为非负数字，收到：$usage_value"
  exit 2
fi

base_dir="$(story_dir "$story")"

if [[ -d "$base_dir" ]]; then
  log_error "Story '$story' already exists at $base_dir"
  exit 1
fi

log_info "Initializing story: $story (init usage=$usage_value codex-context-window-used)"

mkdir -p "$base_dir"

cat > "$base_dir/${story}-requirement.md" << 'EOT'
# <story>：<请填写需求标题>

## 功能描述

<请描述本需求要解决的问题和预期效果>

## 功能范围

### In Scope（必须实现）

1. <功能点1>
2. <功能点2>

### Out of Scope（明确排除）

1. <排除项1>

## 验收标准

| AC-ID | 验收标准 | 验证方式 |
|-------|---------|---------|
| AC-01 | <Given... When... Then...> | 单元测试/代码审查 |
| AC-02 | <Given... When... Then...> | 单元测试/代码审查 |

## 约束备注

| 编号 | 约束类型 | 约束内容 |
|------|---------|---------|
| HC-01 | 技术 | <技术约束，如Java版本、框架限制> |
| HC-02 | 业务 | <业务约束，如合规要求> |

## 假设与风险

| 编号 | 类型 | 内容 | 风险等级 |
|------|------|------|---------|
| AR-01 | 假设 | <假设条件> | M |

## 关联领域知识（可选）

<!-- 如果本需求涉及已有 Domain Knowledge 的模块，在此指定文件路径，PM 和 Designer 将纳入参考 -->
<!-- 示例：iLink-doc/domain/login-410301-domain-knowledge.md -->
<!-- 无关联时删除本节或留空 -->
EOT

sed -i.bak "s/<story>/$story/g" "$base_dir/${story}-requirement.md"
rm -f "$base_dir/${story}-requirement.md.bak"

# v1.6.0: 写入 Usage 追踪文件
timestamp=$(TZ=Asia/Shanghai date +%Y-%m-%dT%H:%M:%S+08:00)
cat > "$base_dir/${story}-usage.md" << EOT
# ${story} — Usage Tracking

| 节点 | 时间戳 | Usage_Value | Usage_Unit |
|------|--------|------------|-----------|
| init | ${timestamp} | ${usage_value} | codex-context-window-used |

**Latest Delta**: (待 review 后计算)

> 说明：用户在 init 和每次 qa 执行前，查询 Codex 的 \`/status\` 显示的 "Context window" used 值并传入命令。中间阶段不追踪。回流多次 qa 时按 review-1, review-2... 递增编号，Latest Delta 始终基于最后一次 review。
>
> **语义提示**：Codex 的 Context window used 反映**当前 context 占用**而非**累计消耗**，受 Codex CLI 自动压缩 / \`/compact\` 影响。Latest Delta 适合作为"当前 context 健康度"指标（值越大说明 story 让 context 越胀），**不适合**等同于"本 story 的成本消耗"。值下降通常意味着发生了 context 压缩，与 session 重置同样会被标注 \`(跨 reset 边界, 不可比)\`。
EOT

reset_retry_count "$base_dir"

log_info "Story '$story' initialized successfully"
echo ""
echo "工作目录: $base_dir"
echo "初始文件: ${story}-requirement.md"
echo "Usage 追踪: ${story}-usage.md (init Context window used=${usage_value})"
echo ""
echo "下一步："
echo "1. 编辑 $base_dir/${story}-requirement.md"
echo "2. 完成后执行: /ilink-pm $story"
