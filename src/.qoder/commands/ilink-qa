#!/usr/bin/env bash
set -euo pipefail

# FR-CMD-04: /ilink-qa <story> <usage-value> - Trigger QA Agent
# v1.6.0: <usage-value> 必填，记录 review 时刻的"已使用 credits"用于 usage 追踪

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$DIR/_common.sh"

# v1.6.0 必填校验：第二参数 <usage-value>
if [[ $# -lt 2 || -z "${2:-}" ]]; then
  echo "❌ 缺少 usage-value 参数。请先在 Qoder 中执行 /usage 查看'已使用 credits'，然后以下列格式重试：" >&2
  echo "" >&2
  echo "  /ilink-qa <story-id> <已使用 credits 数字>" >&2
  echo "" >&2
  echo "例如，/usage 显示已使用 1450 credits，则执行：/ilink-qa kcia-1520 1450" >&2
  echo "" >&2
  echo "无法查询时允许传入 0（语义为'故意跳过'，文件正常追加但 delta 标注不可信）。" >&2
  exit 2
fi

story_required "$@"
story="$1"
usage_value="$2"

# 校验 usage_value 为非负数字
if ! [[ "$usage_value" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
  log_error "usage-value 必须为非负数字，收到：$usage_value"
  exit 2
fi

base_dir="$(story_dir "$story")"

code_doc="$base_dir/${story}-code.master.md"
design_doc="$base_dir/${story}-design.master.md"
pm_doc="$base_dir/${story}-pm.master.md"

require_file "$code_doc"
require_file "$design_doc"
require_file "$pm_doc"

# Check status
status=$(check_status "$code_doc")
if [[ "$status" != "PENDING_QA" ]]; then
  log_warn "Code document status is '$status', expected 'PENDING_QA'"
fi

# Extract Target_Files from code.master.md and validate
target_files=$(extract_metadata "$code_doc" "Target_Files")

whitelist=$(extract_task_allocation_paths "$design_doc" 2>/dev/null || true)

if [[ -n "$target_files" ]]; then
  echo "$target_files" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed '/^$/d' | while read -r f; do
    if [[ ! -f "$f" ]]; then
      log_error "Missing Target_File: $f"
      echo "FAIL" > /tmp/.ilink-qa-check-$$
    fi
    if ! is_path_safe "$f"; then
      log_error "Unsafe path: $f"
      echo "FAIL" > /tmp/.ilink-qa-check-$$
    fi
    if [[ -n "$whitelist" ]]; then
      if ! echo "$whitelist" | grep -Fxq "$f"; then
        log_error "Out of scope Target_File (not in TASK_ALLOCATION): $f"
        echo "FAIL" > /tmp/.ilink-qa-check-$$
      fi
    fi
  done
fi

if [[ -f /tmp/.ilink-qa-check-$$ ]]; then
  rm -f /tmp/.ilink-qa-check-$$
  log_error "QA precheck failed"
  exit 4
fi

echo ""
echo "你现在扮演 iLink 中的 QA（质量审查员）角色。"
echo ""
echo "## 参数"
echo ""
echo "- story: $story"
echo "- usage-value: $usage_value（用户当前已使用 credits）"
echo ""
echo "## 准备工作"
echo ""
echo "依次读取以下文件："
echo "1. project-context.md"
echo "2. iLink/souls/universal.soul.md"
echo "3. iLink/souls/qa.soul.md"
echo ""
echo "## 前置检查"
echo ""
echo "依次读取（任一缺失则提示用户先执行对应角色）："
echo "1. iLink-doc/${story}/${story}-pm.master.md"
echo "2. iLink-doc/${story}/${story}-design.master.md"
echo "3. iLink-doc/${story}/${story}-code.master.md"
echo ""
echo "## 读取源码"
echo ""
echo "从 code.master.md 变更清单中提取所有文件路径，逐一读取磁盘上的实际源码文件。文件不存在则记录为 HIGH severity Issue。"
echo ""
echo "## 执行五步审查"
echo ""
echo "1. 消费 [REVIEW_HANDOFF]（缺失则记录 MISSING_HANDOFF）"
echo "2. 设计符合性审查（对照 design.master.md）"
echo "3. AC 覆盖验收（以 pm.master.md B4 为基准）"
echo "4. 代码质量审查（对照 project-context.md）"
echo "5. 回流复核（仅回流时）"
echo ""
echo "## 输出 review.master.md"
echo ""
echo "写入：iLink-doc/${story}/${story}-review.master.md"
echo "Status: COMPLETED / FAIL_BACK_TO_CODER / STAGING"
echo ""
echo "## 追加 Usage 追踪行（v1.6.0 MUST）"
echo ""
echo "写完 review.master.md 后，执行 Usage 追踪："
echo ""
echo "1. 读取 iLink-doc/${story}/${story}-usage.md"
echo "   - 文件不存在 → 警告，不阻塞 Status 推进"
echo "2. 统计现有 review-N 行数，本次追加为 review-(N+1)"
echo "3. 执行 TZ=Asia/Shanghai date +%Y-%m-%dT%H:%M:%S+08:00 取当前时间戳"
echo "4. 在表格末尾（**Latest Delta** 行之前）插入一行："
echo "   | review-<N+1> | <时间戳> | ${usage_value} | qoder-credits-cumulative |"
echo "5. 计算 Latest Delta：${usage_value} - <init 行的 Usage_Value>"
echo "   - 正数 → **Latest Delta**: <delta> (qoder-credits-cumulative)"
echo "   - 负数 → **Latest Delta**: (跨 reset 边界, 不可比)"
echo "   - init 或本次为 0 → **Latest Delta**: <delta> (含 0 值, 不可信)"
echo "6. Usage_Unit 硬编码 qoder-credits-cumulative，不接受用户输入"
echo ""
echo "> 详细协议见 Root Spec §8.1.2。usage 文件不参与契约链，缺失或写入失败 SHALL NOT 阻塞 Status 推进。"
echo ""
echo "## Usage 追加校验（v1.6.0 MUST）"
echo ""
echo "完成 usage.md 追加后，MUST 向用户回报："
echo "1. 追加的行标识（review-N）"
echo "2. Latest Delta 计算结果"
echo "3. 若跳过 usage 追加，回报原因（文件缺失/值异常等）"
echo ""
echo "## 完成后"
echo ""
echo "- COMPLETED → Story 完成，建议 git commit"
echo "- FAIL_BACK_TO_CODER → 提示用户执行 /ilink-coder ${story} 回流修复"
echo "- STAGING → 展示 [UPSTREAM_BLOCKERS]，建议用户与 Designer 讨论"
